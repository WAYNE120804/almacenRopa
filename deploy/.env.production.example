APP_DOMAIN=almacen.example.com
API_DOMAIN=api.almacen.example.com
BOT_DOMAIN=bot.almacen.example.com
WA_DOMAIN=wa.almacen.example.com

POSTGRES_DB=almacen_ropa
POSTGRES_USER=almacen_user
POSTGRES_PASSWORD=change-me

BACKEND_PORT=3002
BACKEND_NODE_ENV=production
BACKEND_DATABASE_URL=postgresql://almacen_user:change-me@postgres:5432/almacen_ropa
BACKEND_AUTH_SECRET=change-this-auth-secret
BACKEND_AUTH_TTL_SECONDS=43200
BACKEND_BOOTSTRAP_ADMIN_NAME=Administrador Principal
BACKEND_BOOTSTRAP_ADMIN_EMAIL=admin@almacen.example.com
BACKEND_BOOTSTRAP_ADMIN_PASSWORD=change-me

N8N_HOST=bot.almacen.example.com
N8N_PROTOCOL=https
N8N_PORT=5678
N8N_EDITOR_BASE_URL=https://bot.almacen.example.com/
WEBHOOK_URL=https://bot.almacen.example.com/
N8N_ENCRYPTION_KEY=change-me-n8n-encryption-key
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me
N8N_PROXY_HOPS=1
N8N_RUNNERS_ENABLED=true
N8N_DIAGNOSTICS_ENABLED=false
N8N_PERSONALIZATION_ENABLED=false
N8N_EXECUTIONS_MODE=queue
N8N_OFFLOAD_MANUAL_EXECUTIONS_TO_WORKERS=true
N8N_QUEUE_BULL_REDIS_HOST=redis
N8N_QUEUE_BULL_REDIS_PORT=6379
N8N_QUEUE_BULL_REDIS_PASSWORD=
N8N_QUEUE_HEALTH_CHECK_ACTIVE=true

N8N_DB_TYPE=postgresdb
N8N_DB_POSTGRESDB_HOST=postgres
N8N_DB_POSTGRESDB_PORT=5432
N8N_DB_POSTGRESDB_DATABASE=almacen_ropa
N8N_DB_POSTGRESDB_USER=almacen_user
N8N_DB_POSTGRESDB_PASSWORD=change-me

EVOLUTION_SERVER_URL=https://wa.almacen.example.com
EVOLUTION_AUTHENTICATION_API_KEY=change-me-evolution-api-key
EVOLUTION_TELEMETRY=false
EVOLUTION_DATABASE_ENABLED=true
EVOLUTION_DATABASE_PROVIDER=postgresql
EVOLUTION_DATABASE_CONNECTION_URI=postgresql://almacen_user:change-me@postgres:5432/almacen_ropa
EVOLUTION_DATABASE_CONNECTION_CLIENT_NAME=evolution_exchange
EVOLUTION_DATABASE_SAVE_DATA_INSTANCE=true
EVOLUTION_DATABASE_SAVE_DATA_NEW_MESSAGE=true
EVOLUTION_DATABASE_SAVE_MESSAGE_UPDATE=true
EVOLUTION_DATABASE_SAVE_DATA_CONTACTS=true
EVOLUTION_DATABASE_SAVE_DATA_CHATS=true
EVOLUTION_DATABASE_SAVE_DATA_LABELS=true
EVOLUTION_DATABASE_SAVE_DATA_HISTORIC=true
EVOLUTION_CACHE_REDIS_ENABLED=true
EVOLUTION_CACHE_REDIS_URI=redis://redis:6379/6
EVOLUTION_DEL_INSTANCE=false
EVOLUTION_CONFIG_SESSION_PHONE_CLIENT=AlmacenRopa
EVOLUTION_CONFIG_SESSION_PHONE_NAME=Chrome
EVOLUTION_WEBSOCKET_ENABLED=true
EVOLUTION_WEBSOCKET_GLOBAL_EVENTS=true
EVOLUTION_LOG_LEVEL=ERROR,WARN,INFO,LOG
EVOLUTION_LOG_COLOR=true

FRONTEND_VITE_API_URL=https://api.almacen.example.com/api
