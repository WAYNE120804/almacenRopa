POSTGRES_DB=rifas
POSTGRES_USER=rifas_user
POSTGRES_PASSWORD=change-me

BACKEND_PORT=3002
BACKEND_NODE_ENV=production
BACKEND_DATABASE_URL=postgresql://rifas_user:change-me@postgres:5432/rifas
BACKEND_AUTH_SECRET=change-this-auth-secret
BACKEND_AUTH_TTL_SECONDS=43200
BACKEND_BOOTSTRAP_ADMIN_NAME=Administrador Principal
BACKEND_BOOTSTRAP_ADMIN_EMAIL=admin@rifasmejia.store
BACKEND_BOOTSTRAP_ADMIN_PASSWORD=change-me

BACKEND_WOMPI_ENV=production
BACKEND_WOMPI_PUBLIC_KEY=
BACKEND_WOMPI_PRIVATE_KEY=
BACKEND_WOMPI_EVENTS_SECRET=
BACKEND_WOMPI_INTEGRITY_SECRET=
BACKEND_WOMPI_REDIRECT_URL=https://rifasmejia.store/publico/pago/retorno
BACKEND_WOMPI_WEBHOOK_URL=https://api.rifasmejia.store/api/checkout-publico/wompi/webhook

N8N_HOST=bot.rifasmejia.store
N8N_PROTOCOL=https
N8N_PORT=5678
N8N_EDITOR_BASE_URL=https://bot.rifasmejia.store/
WEBHOOK_URL=https://bot.rifasmejia.store/
N8N_ENCRYPTION_KEY=change-me-n8n-encryption-key
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me
N8N_PROXY_HOPS=1
N8N_RUNNERS_ENABLED=true
N8N_DIAGNOSTICS_ENABLED=false
N8N_PERSONALIZATION_ENABLED=false

N8N_DB_TYPE=postgresdb
N8N_DB_POSTGRESDB_HOST=postgres
N8N_DB_POSTGRESDB_PORT=5432
N8N_DB_POSTGRESDB_DATABASE=rifas
N8N_DB_POSTGRESDB_USER=rifas_user
N8N_DB_POSTGRESDB_PASSWORD=change-me

FRONTEND_VITE_API_URL=https://api.rifasmejia.store/api
